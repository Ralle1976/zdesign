l"}, {"id": "pricing-price", "type": "text", "tag": "p", "style": {"fontSize": "42px", "fontWeight": "700", "color": "#10b981", "marginBottom": "8px"}}, "$49"}, {"id": "pricing-period", "type": "text", "tag": "p", "style